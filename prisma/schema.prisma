generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  nombre          String
  dni       String   @unique
  email           String    @unique
  passwordHash    String
  rol             Role      @default(CLIENTE)
  telefono        String?
  fechaCreacion   DateTime  @default(now())
  pedidosCliente  Order[]   @relation("ClienteOrders")
  viajesProveedor Order[]   @relation("ProveedorOrders")
  vehiculos Vehicle[]

}

model Vehicle {
  id             String            @id @default(uuid())
  id_proveedor   String
  tipo_vehiculo  String
  patente        String            @unique
  modelo         String?
  capacidadVol   Float
  capacidadPeso  Float
  estaHabilitado Boolean           @default(false)
  orders         Order[]
  proveedor      User              @relation(fields: [id_proveedor], references: [id])
  documentos     VehicleDocument[]
}

model VehicleDocument {
  id               String    @id @default(uuid())
  vehicleId        String
  tipo             DocType
  fileUrl          String
  fechaVencimiento DateTime
  estado           DocStatus @default(PENDIENTE)
  observaciones    String?
  vehiculo         Vehicle   @relation(fields: [vehicleId], references: [id])
}

model Order {
  id             String       @id @default(uuid())
  tipo           ServiceType
  estado         OrderStatus  @default(BUSCANDO)
  clienteId      String
  proveedorId    String?
  vehiculoId     String?
  distanciaTotal Float
  precioTotal    Float
  comisionApp    Float
  fechaServicio  DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  cliente        User         @relation("ClienteOrders", fields: [clienteId], references: [id])
  proveedor      User?        @relation("ProveedorOrders", fields: [proveedorId], references: [id])
  vehiculo       Vehicle?     @relation(fields: [vehiculoId], references: [id])
  review         Review?
  paradas        Stop[]
  transaccion    Transaction?
}

model Stop {
  id          String  @id @default(uuid())
  orderId     String
  direccion   String
  lat         Float
  lng         Float
  ordenVisita Int
  esEntrega   Boolean @default(true)
  order       Order   @relation(fields: [orderId], references: [id])
}

model Transaction {
  id         String   @id @default(uuid())
  orderId    String   @unique
  monto      Float
  metodoPago String
  estadoPago String
  fecha      DateTime @default(now())
  order      Order    @relation(fields: [orderId], references: [id])
}

model Review {
  id           String  @id @default(uuid())
  orderId      String  @unique
  calificacion Int
  comentario   String?
  order        Order   @relation(fields: [orderId], references: [id])
}

enum Role {
  CLIENTE
  PROVEEDOR
  ADMIN
}

enum DocType {
  SEGURO
  VTV
  LICENCIA
  CEDULA
}

enum DocStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum ServiceType {
  MANDADO
  FLETE
}

enum OrderStatus {
  BUSCANDO
  ASIGNADO
  EN_VIAJE
  ENTREGADO
  CANCELADO
}
